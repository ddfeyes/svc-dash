# ─── Symbols ──────────────────────────────────────────────────────────────────
# Comma-separated list of symbols to track (overrides SYMBOL_BINANCE/SYMBOL_BYBIT)
SYMBOLS=BANANAS31USDT,COSUSDT,DEXEUSDT,LYNUSDT

# Legacy single-symbol fallback (used only if SYMBOLS is not set)
# SYMBOL_BINANCE=BANANAS31USDT
# SYMBOL_BYBIT=BANANAS31USDT

# ─── API Keys (optional, for private endpoints) ───────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=data/bananas31.db

# ─── Polling interval (seconds) ───────────────────────────────────────────────
POLL_INTERVAL=1
